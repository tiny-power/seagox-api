<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seagox.lowcode.business.mapper.PaymentRequestMapper">

    <sql id="projectNameCondition">
        <if test="params.projectName != null and params.projectName != ''">
            <choose>
                <when test="_databaseId == 'mysql'">AND p.name LIKE CONCAT('%', #{params.projectName}, '%')</when>
                <otherwise>AND p.name LIKE '%' || #{params.projectName} || '%'</otherwise>
            </choose>
        </if>
    </sql>

    <sql id="paymentRequestColumns">
        SELECT a.*, p.code AS "projectCode", p.name AS "projectName",
               applicant.name AS "applicantName", creator.name AS "createdByName"
        FROM payment_request a
        LEFT JOIN project p ON p.id = a.project_id
        LEFT JOIN sys_account applicant ON applicant.id = a.applicant_id
        LEFT JOIN sys_account creator ON creator.id = a.created_by
    </sql>

    <select id="queryPaymentRequests" resultType="camelKeyMap">
        <include refid="paymentRequestColumns"/>
        <where>
            <include refid="projectNameCondition"/>
            <if test="params.applicantName != null and params.applicantName != ''">
                <choose>
                    <when test="_databaseId == 'mysql'">AND applicant.name LIKE CONCAT('%', #{params.applicantName}, '%')</when>
                    <otherwise>AND applicant.name LIKE '%' || #{params.applicantName} || '%'</otherwise>
                </choose>
            </if>
            <if test="params.status != null and params.status != ''">AND a.status = #{params.status}</if>
        </where>
        ORDER BY a.created_at DESC, a.id DESC
    </select>

    <select id="queryPaymentRequestById" resultType="camelKeyMap">
        <include refid="paymentRequestColumns"/>
        WHERE a.id = #{id}
    </select>

</mapper>
